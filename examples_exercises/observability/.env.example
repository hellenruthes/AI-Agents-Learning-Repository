# =============================================================================
# API Keys - Get your keys from the respective platforms
# =============================================================================

# Anthropic API Key (Required for Claude models)
# Get it from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API Key (Optional - for GPT models)
# Get it from: https://platform.openai.com/api-keys
# Note: ChatGPT and OpenAI API use the same key
OPENAI_API_KEY=your-openai-api-key-here

# Google Gemini API Key (Optional - for Gemini models)
# Get it from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# =============================================================================
# Langfuse Configuration (Required for observability)
# =============================================================================

# Langfuse Cloud Configuration
# Get your keys from: https://cloud.langfuse.com/settings
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional: Self-hosted Langfuse
# If you're running Langfuse locally, uncomment and update:
# LANGFUSE_HOST=http://localhost:3000
